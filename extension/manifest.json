{
    "manifest_version": 3,
    "name": "EventSense AI Demo",
    "description": "Extracts Gmail content and detects event details",
    "version": "1.0",
    "permissions": ["activeTab", "scripting"],
    "action": {
      "default_popup": "popup.html"
    },
    "content_scripts": [
      {
        "matches": ["https://mail.google.com/*"],
        "js": ["content.js"]
      }
    ]
  }
  